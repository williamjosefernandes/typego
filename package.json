{
  "name": "typego",
  "version": "1.0.0",
  "description": "TypeScript-first backend framework that compiles to Go",
  "type": "module",
  "license": "MIT",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "bin": {
    "typego": "./bin/typego.js"
  },
  "files": [
    "bin",
    "dist",
    "runtime-go",
    "templates",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"import('node:fs').then(fs=>fs.rmSync('dist',{recursive:true,force:true}))\"",
    "dev": "node ./bin/typego.js dev",
    "start": "node ./bin/typego.js start",
    "create": "node ./bin/typego.js create",
    "generate": "node ./bin/typego.js generate",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "typego",
    "typescript",
    "go",
    "framework",
    "cli"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "typescript": "^5.8.3"
  }
}
